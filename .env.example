# Copy to .env and fill in.

# Database — SQLite for local dev. For production use Postgres, e.g.:
# DATABASE_URL="postgresql://user:pass@host:5432/kanbai?schema=public"
DATABASE_URL="file:./dev.db"

# Public base URL of the app (used in docs/links shown to agents).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Long random secret mixed into API-key hashing (defense-in-depth).
# Generate: openssl rand -hex 32
KANBAI_KEY_PEPPER="change-me-to-a-long-random-value"
